# server/.env  (이 파일을 .env 로 복사해서 채우세요)
# 없으면 /analyze 는 규칙 기반 fallback 정리를 사용합니다(개발용).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 분석에 필요한 최소 글 편수 (기본 14). 짧은 세션/시연에서는 낮추세요.
# 프론트 VITE_TOTAL_DAYS 와 반드시 같은 값이어야 합니다.
# MIN_ENTRIES=3
# 일반 계정 분석에 사용할 최대 편수와 1편 테스트 계정 (선택)
# MAX_ENTRIES=3
# TEST_ACCOUNT_EMAIL=test@example.com

# 공개 배포 시 /analyze 에 공유 토큰을 걸려면 (프론트 VITE_ANALYZE_TOKEN 와 동일하게)
# ANALYZE_TOKEN=
